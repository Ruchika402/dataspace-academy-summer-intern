{
  "rewrites": [
    {
      "source": "/api/login/",
      "destination": "https://threathunter-api.onrender.com/api/login/"
    },
    {
      "source": "/api/login",
      "destination": "https://threathunter-api.onrender.com/api/login/"
    },
    {
      "source": "/api/register/",
      "destination": "https://threathunter-api.onrender.com/api/register/"
    },
    {
      "source": "/api/register",
      "destination": "https://threathunter-api.onrender.com/api/register/"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://threathunter-api.onrender.com/api/$1"
    },
    {
      "source": "/admin/(.*)",
      "destination": "https://threathunter-api.onrender.com/admin/$1"
    },
    {
      "source": "/static/admin/(.*)",
      "destination": "https://threathunter-api.onrender.com/static/admin/$1"
    }
  ]
}
